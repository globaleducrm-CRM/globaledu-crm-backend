generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SchoolStatus {
  APPROVED
  PENDING
  INACTIVE
  SUSPENDED
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum StudentStatus {
  ACTIVE
  INACTIVE
  TRANSFERRED
  DROPPED
}

model Role {
  id              String           @id @default(uuid())
  name            String           @unique
  description     String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  rolePermissions RolePermission[]
  users           User[]
}

model Permission {
  id              String           @id @default(uuid())
  name            String           @unique
  description     String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  rolePermissions RolePermission[]
}

model RolePermission {
  id           String     @id @default(uuid())
  roleId       String
  permissionId String
  createdAt    DateTime   @default(now())
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

model User {
  id                  String   @id @default(uuid())
  schoolId            String?
  roleId              String?

  name                String
  email               String   @unique
  mobile              String?  @unique
  password            String

  isActive            Boolean  @default(true)

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  resetPasswordExpire DateTime?
  resetPasswordToken  String?



  role                Role?    @relation(fields: [roleId], references: [id])
  school              School?  @relation(fields: [schoolId], references: [id])

  // No teacherId
  teacher             Teacher?
  student Student?
  parent Parent?



  auditLogs           AuditLog[]
  generatedStudentIdCards StudentIdCard[]
  transferCertificates TransferCertificate[]
}

model School {
  id              String            @id @default(uuid())
  name            String            @unique(map: "School_schoolName_key")
  schoolCode      String            @unique
  board           String
  affiliationNo   String?
  email           String
  phone           String
  website         String?
  logo            String?
  addressLine     String
  city            String
  district        String
  state           String
  pincode         String?
  country         String
  principalName   String?
  status          SchoolStatus      @default(PENDING)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  adminEmail      String?
  adminName       String?
  adminPhone      String?
  banner          String?
  ownerEmail      String?
  ownerName       String?
  ownerPhone      String?
  principalEmail  String?
  principalPhone  String?
  schoolBoardCode String
  sessions        AcademicSession[]
  auditLogs       AuditLog[]
  classes         Class[]
  parents         Parent[]
  sections        Section[]
  students        Student[]
  subjects        Subject[]
  teachers        Teacher[]
  timetables  Timetable[]
  users           User[]
  feeInvoiceBatches FeeInvoiceBatch[]
  feeInvoices FeeInvoice[]

  // Fee Module

  feeHeads          FeeHead[]

  feeStructures     FeeStructure[]

  feeDiscounts      FeeDiscount[]

  

  feeFines          FeeFine[]

  teacherSubjects TeacherSubject[]
  timetableConfigs TimetableConfig[]
  studentEnrollments StudentEnrollment[]
  transferCertificates TransferCertificate[]
  

  studentIdCardTemplates StudentIdCardTemplate[]
  studentIdCards         StudentIdCard[]

  @@index([schoolCode])
}

model AcademicSession {
  id          String    @id @default(uuid())
  schoolId    String
  sessionName String
  startDate   DateTime
  endDate     DateTime
  isCurrent   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  school      School    @relation(fields: [schoolId], references: [id])
  classes     Class[]
  students    Student[]
  sections    Section[]
  subjects    Subject[]
  teachers    Teacher[]
  feeInvoiceBatches FeeInvoiceBatch[]
  feeStructures FeeStructure[]
  timetables  Timetable[]
  feeInvoices FeeInvoice[]
  timetableConfigs TimetableConfig[]
  studentEnrollments StudentEnrollment[]
  transferCertificates TransferCertificate[]
  studentIdCardTemplates StudentIdCardTemplate[]
  studentIdCards         StudentIdCard[]



  @@index([schoolId])
}

model Class {
  id         String          @id @default(uuid())
  schoolId   String
  
  className  String
  sortName   String
  classOrder Int?
  status     Boolean         @default(true)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  school     School          @relation(fields: [schoolId], references: [id])
  sessionId  String
  session    AcademicSession @relation(fields: [sessionId], references: [id])
  sections   Section[]
  students   Student[]
  feeInvoiceBatches FeeInvoiceBatch[]
  teacherSubjects TeacherSubject[]
  studentEnrollments StudentEnrollment[]
  timetables  Timetable[]
  feeStructures FeeStructure[]
  timetableConfigs TimetableConfig[]
  feeInvoices FeeInvoice[]

  @@unique([schoolId, sessionId, className])
  @@index([schoolId])
  @@index([sessionId])
}



model Section {
  id          String    @id @default(uuid())
  schoolId    String
  classId     String
  sectionName String
  capacity    Int?
  
  classTeacherId     String?
  coClassTeacherId   String?
  status      Boolean    @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  class       Class     @relation(fields: [classId], references: [id])
  school      School    @relation(fields: [schoolId], references: [id])
   
  classTeacher       Teacher?        @relation("ClassTeacher", fields: [classTeacherId], references: [id])
  coClassTeacher     Teacher?        @relation("CoClassTeacher", fields: [coClassTeacherId], references: [id])
  sessionId  String?
  session    AcademicSession? @relation(fields: [sessionId], references: [id])
  students    Student[]
  teacherSubjects   TeacherSubject[]
  timetables  Timetable[]
  studentEnrollments StudentEnrollment[]
  timetableConfigs TimetableConfig[]
  feeInvoices FeeInvoice[]
  feeInvoiceBatches FeeInvoiceBatch[]

// Session-wise unique
  @@unique([classId,sessionId, sectionName])
  @@index([schoolId])
  @@index([classId])
}

model Subject {
  id          String   @id @default(uuid())
  schoolId    String

  subjectName String
  shortName   String?      // ENG, MAT, SCI
  subjectCode String

  description String?      // Optional
  
  

  status      Boolean  @default(true)

  teacherSubjects TeacherSubject[]
  periods     TimetablePeriod[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  school      School   @relation(fields: [schoolId], references: [id])

  sessionId  String?
  session    AcademicSession? @relation(fields: [sessionId], references: [id])

  // Session-wise unique
  @@unique([schoolId, sessionId, subjectCode])
  @@unique([schoolId, sessionId, subjectName])

  @@index([schoolId])
  @@index([sessionId])
}


enum EmployeeType {
  TEACHER
  ACCOUNTANT
  CLERK
  LIBRARIAN
  RECEPTIONIST
  PRINCIPAL
  VICE_PRINCIPAL
  COORDINATOR
  SPORTS_TEACHER
  LAB_ASSISTANT
  TRANSPORT_MANAGER
  DRIVER
  CONDUCTOR
  SECURITY_GUARD
  PEON
  HOSTEL_WARDEN
  NURSE
  OTHER
}

model Teacher {
  id            String    @id @default(uuid())
  schoolId      String
  image         String?
  employeeId    String
  firstName     String
  lastName      String?
  gender        Gender?
  type          EmployeeType @default(TEACHER)
  notes         String?

  email         String?
  mobile        String?
  dob           DateTime?
  qualification String?
  experience    Int?
  salary        Decimal? @db.Decimal(10,2)

  status        Boolean @default(true)

  joiningDate   DateTime?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  school        School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  userId        String? @unique
  user          User?   @relation(fields: [userId], references: [id])
  sessionId  String?
  session    AcademicSession? @relation(fields: [sessionId], references: [id])

  subjects      TeacherSubject[]
  
  timetablePeriods TimetablePeriod[] @relation("TeacherPeriods")

  classTeacherSections   Section[] @relation("ClassTeacher")
  coClassTeacherSections Section[] @relation("CoClassTeacher")

  // Session-wise unique
  @@unique([schoolId, sessionId, employeeId])
  @@index([schoolId])
  @@index([sessionId])
}

model TeacherSubject {
  id          String @id @default(uuid())
  schoolId    String
  teacherId   String
  classId     String
  sectionId   String
  subjectId   String

  school      School  @relation(fields: [schoolId], references: [id])
  teacher     Teacher @relation(fields: [teacherId], references: [id])
  class       Class   @relation(fields: [classId], references: [id])
  section     Section @relation(fields: [sectionId], references: [id])
  subject     Subject @relation(fields: [subjectId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([schoolId])
  @@index([teacherId])
  @@unique([teacherId, classId, sectionId, subjectId])
}


model Parent {
  id             String   @id @default(uuid())
  schoolId       String

  fatherName     String
  fatherMobile   String
  fatherEmail    String

  motherName     String?
  motherMobile   String?
  motherEmail    String?

  

  address        String?
  city           String?
  state          String?
  pincode        String?

  fatherOccupation String?
  motherOccupation String?

  fatherAadhaar    String?
  motherAadhaar    String?

  annualIncome     Float?

  officeAddress    String?
  status        Boolean @default(true)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  school         School @relation(fields: [schoolId], references: [id])
  userId          String? @unique
  user            User? @relation(fields: [userId], references: [id])
  students       Student[]

  @@index([schoolId])
  @@unique([schoolId, fatherEmail])
}



model Student {
  id              String          @id @default(uuid())

  schoolId        String
  sessionId       String
  parentId        String?

  classId         String?
  sectionId       String?

  admissionNo     String
  rollNo          Int?

  image           String?

  firstName       String
  middleName      String?
  lastName        String?

  email           String
  mobile          String

  gender          Gender?
  dob             DateTime?

  bloodGroup      String?
  nationality     String? @default("India")

  religion        String?
  caste           String?
  category        String?

  previousSchool  String?

  admissionDate   DateTime @default(now())

  transport       Boolean @default(false)
  hostel          Boolean @default(false)

  medicalHistory  String?

 

  // NEW FIELDS

  address         String?
  city            String?
  state           String?
  pincode         String?
  country         String? @default("India")

  height          Float?
  weight          Float?

  status          StudentStatus @default(ACTIVE)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  school          School           @relation(fields: [schoolId], references: [id])
  session         AcademicSession  @relation(fields: [sessionId], references: [id])

  class           Class?           @relation(fields: [classId], references: [id])
  section         Section?         @relation(fields: [sectionId], references: [id])

  parent          Parent?          @relation(fields: [parentId], references: [id])

  // Fee Module Relations
  feeAssignments  StudentFeeAssignment[]
  feeDiscounts    FeeDiscount[]
  feeInvoices     FeeInvoice[]
  feeFines        FeeFine[]

   // NEW
  feeOverrides    StudentFeeOverride[]
  idCards StudentIdCard[]

  userId          String? @unique
  user            User? @relation(fields: [userId], references: [id])

  transportInfo StudentTransport?
  studentEnrollments StudentEnrollment[]
  transferCertificates TransferCertificate[]

  @@unique([schoolId, admissionNo])
  @@unique([schoolId, email])

  @@index([schoolId])
  @@index([sessionId])
  @@index([classId])
  @@index([sectionId])
  @@index([parentId])
}



model StudentTransport{
    id String @id @default(uuid())

    studentId String @unique

    transportRequired Boolean @default(false)

    pickupPoint String?
    pickupTime String?
    dropTime String?

    conductorName String?
    conductorPhone String?

    student Student @relation(fields:[studentId],references:[id])

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

enum PromotionResult {
  PROMOTED
  FAILED
  RETAINED
}

model StudentEnrollment {

  id String @id @default(uuid())

  schoolId String

  studentId String
  sessionId String
  classId String
  sectionId String

  rollNo Int?

  promotionResult PromotionResult

  promotedAt DateTime @default(now())
  createdAt DateTime @default(now())

  school School @relation(fields:[schoolId], references:[id])

  student Student @relation(fields:[studentId], references:[id], onDelete: Cascade)

  session AcademicSession @relation(fields:[sessionId], references:[id], onDelete: Cascade)

  class Class @relation(fields:[classId], references:[id], onDelete: Cascade)

  section Section @relation(fields:[sectionId], references:[id], onDelete: Cascade)

  @@unique([studentId, sessionId])

  @@index([schoolId])
  @@index([studentId])
  @@index([sessionId])
  @@index([classId])
  @@index([sectionId])
  @@index([promotionResult])
}

enum TCStatus {
  ISSUED
  CANCELLED
}

model TransferCertificate {
  id          String   @id @default(uuid())
  tcNumber    String   @unique

  // Relations
  studentId   String
  schoolId    String
  sessionId   String?
  createdById String?

  student      Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  school       School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  session      AcademicSession? @relation(fields: [sessionId], references: [id])
  createdBy    User?    @relation(fields: [createdById], references: [id])

  // Student Snapshot
  admissionNo     String?
  studentName     String?
  fatherName      String?
  motherName      String?
  dateOfBirth     DateTime?
  admissionDate   DateTime?
  nationality     String?
  category        String?
  className       String?
  sectionName     String?
  board           String?
  medium          String?

  // TC Details
  applicationDate    DateTime?
  lastAttendanceDate DateTime?
  issueDate          DateTime @default(now())

  reason             String?
  conduct            String?
  remarks            String?
  promotedToClass    String?
  result             String?

  // Attendance
  workingDays        Int?
  presentDays        Int?

  // Other Information
  subjects           String?
  duesPaid           Boolean?
  concession         Boolean?
  nccScout           Boolean?
  activities         Boolean?

  // Register Details
  bookNo             String?
  srNo               String?

  // PDF
  pdfUrl             String?

  // Status
  status             TCStatus @default(ISSUED)

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  deletedAt          DateTime?

  @@index([studentId])
  @@index([schoolId])
  @@index([sessionId])
  @@index([createdById])
  @@index([tcNumber])

  @@map("transfer_certificates")
}



enum TimetableType {
  CLASS_WISE
  DAY_WISE
  TEACHER_WISE
}

enum TimetableStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}



model Timetable {
  id         String @id @default(uuid())

  name       String
  classId    String
  sectionId  String
  
  schoolId   String
  sessionId  String
  status     TimetableStatus @default(DRAFT)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  class       Class?            @relation(fields: [classId], references: [id])
  section     Section?          @relation(fields: [sectionId], references: [id])
  school      School            @relation(fields: [schoolId], references: [id])
  session     AcademicSession   @relation(fields: [sessionId], references: [id])

  periods     TimetablePeriod[]

  @@unique([schoolId, sessionId, classId, sectionId])
  @@map("timetables")
}

model TimetablePeriod {

  id          String @id @default(uuid())

  timetableId String

  day         DayOfWeek

  subjectId   String?
  teacherId   String?
  periodMasterId String
  roomNo      String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  timetable   Timetable @relation(fields: [timetableId], references: [id], onDelete: Cascade)
  subject     Subject?  @relation(fields: [subjectId], references: [id])
  teacher     Teacher?  @relation("TeacherPeriods", fields: [teacherId], references: [id])
  periodMaster   PeriodMaster @relation(fields: [periodMasterId], references: [id])

  @@unique([timetableId, day,periodMasterId])

  @@map("timetable_periods")
}

enum WeekDay {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

model TimetableConfig {
  id               String   @id @default(uuid())

  schoolId         String
  sessionId        String?

  classId          String
  sectionId        String

  startTime        String
  endTime          String

  slotDuration     Int
  breakDuration    Int
  lunchDuration    Int

  lunchStart       String?
  enableLunchBreak Boolean @default(false)

  breakAfterSlots  Int
  totalSlotsPerDay Int

  schoolDays       WeekDay[]

  isActive         Boolean  @default(true)

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  school           School             @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  session          AcademicSession?   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  class            Class              @relation(fields: [classId], references: [id], onDelete: Cascade)
  section          Section?           @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  periods          PeriodMaster[]

  @@unique([schoolId, sessionId, classId, sectionId])

  @@index([schoolId])
  @@index([sessionId])
  @@index([classId])
  @@index([sectionId])
}



model PeriodMaster {
  id                String   @id @default(uuid())

  timetableConfigId String

  periodNo          Int
  name              String

  startTime         String
  endTime           String

  isBreak           Boolean @default(false)
  status            Boolean @default(true)

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  timetableConfig   TimetableConfig @relation(fields: [timetableConfigId], references: [id], onDelete: Cascade)

  timetablePeriods  TimetablePeriod[]

  @@unique([timetableConfigId, periodNo])
  @@index([timetableConfigId])
}




enum FeeFrequency {
  ONE_TIME
  MONTHLY
  QUARTERLY
  HALF_YEARLY
  YEARLY
}

enum InvoiceStatus {
  PENDING
  PARTIAL
  PAID
  OVERDUE
  CANCELLED
}

enum PaymentMode {
  CASH
  CHEQUE
  UPI
  CARD
  NET_BANKING
  NEFT
  RTGS
}

enum DiscountType {
  FIXED
  PERCENTAGE
}



model FeeHead {
  id            String   @id @default(uuid())

  schoolId      String

  feeHeadName   String
  

  frequency     FeeFrequency

  description   String?

  taxable       Boolean @default(false)

  isActive      Boolean @default(true)

  school         School @relation(fields: [schoolId], references: [id])

  structureItems FeeStructureItem[]

  invoiceItems   FeeInvoiceItem[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([schoolId, feeHeadName])
  @@index([schoolId])
}


model FeeStructure {

  id            String @id @default(uuid())

  schoolId      String

  sessionId     String

  classId       String

  name          String

  status      Boolean @default(true)

  school         School @relation(fields:[schoolId],references:[id])

  session        AcademicSession @relation(fields:[sessionId],references:[id])

  class          Class @relation(fields:[classId],references:[id])

  items          FeeStructureItem[]

  assignments    StudentFeeAssignment[]


  createdAt      DateTime @default(now())

  updatedAt      DateTime @updatedAt

  @@unique([sessionId,classId])

  @@index([schoolId])

}


model FeeStructureItem {

  id String @id @default(uuid())

  feeStructureId String

  feeHeadId String

  applyTo String

  amount Decimal

  concession Decimal @default(0)

  remark String?

  feeStructure FeeStructure @relation(fields:[feeStructureId], references:[id], onDelete: Cascade)

  feeHead FeeHead @relation(fields:[feeHeadId], references:[id])
    // NEW
  studentOverrides StudentFeeOverride[]

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt
}


model StudentFeeOverride {

  id               String @id @default(uuid())

  studentId        String
  feeStructureItemId String

  amount           Decimal @db.Decimal(10,2)
  concession       Decimal @default(0) @db.Decimal(10,2)

  applyTo          String

  remark           String?

  student          Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  feeStructureItem FeeStructureItem @relation(fields: [feeStructureItemId], references: [id], onDelete: Cascade)

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([studentId, feeStructureItemId])
}

model StudentFeeAssignment {

  id             String @id @default(uuid())

  studentId      String

  feeStructureId String

  assignedAt DateTime @default(now())

  student Student  @relation(fields:[studentId],references:[id])

  feeStructure FeeStructure  @relation(fields:[feeStructureId],references:[id])

  createdAt DateTime @default(now())

  @@unique([studentId,feeStructureId])

}


model FeeDiscount {

  id String @id @default(uuid())

  schoolId String

  studentId String

  discountType DiscountType

  value Decimal @db.Decimal(10,2)

  reason String?

  validFrom DateTime?

  validTo DateTime?

  school School @relation(fields:[schoolId],references:[id])

  student Student @relation(fields:[studentId],references:[id])

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@index([schoolId])

}


model FeeInvoice {

  id String @id @default(uuid())

  schoolId String

  studentId String

  sessionId String

  classId String

  sectionId String

  invoiceNo String @unique

  invoiceName String?

  invoiceDate DateTime @default(now())

  dateFrom DateTime?

  dateTo DateTime?

  dueDate DateTime?

  totalAmount Decimal @db.Decimal(10,2)

  discountAmount Decimal @default(0) @db.Decimal(10,2)

  fineAmount Decimal @default(0) @db.Decimal(10,2)

  paidAmount Decimal @default(0) @db.Decimal(10,2)

  pendingAmount Decimal @db.Decimal(10,2)

  status InvoiceStatus @default(PENDING)

  school School @relation(fields:[schoolId],references:[id])

  batchId String?

  batch FeeInvoiceBatch? @relation(fields: [batchId], references: [id], onDelete: Cascade)

  student Student @relation(fields:[studentId],references:[id])

  session AcademicSession @relation(fields:[sessionId],references:[id])

  class Class @relation(fields:[classId],references:[id])

  section Section @relation(fields:[sectionId],references:[id])

  items FeeInvoiceItem[]

  payments FeePayment[]

  receipts FeeReceipt[]

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@index([schoolId])
  @@index([batchId])
  @@index([studentId])
  @@index([sessionId])
  @@index([classId])
  @@index([sectionId])
  @@index([status])
}



model FeeInvoiceItem {

  id String @id @default(uuid())

  invoiceId String

  feeHeadId String

  amount Decimal @db.Decimal(10,2)

  concession Decimal @default(0) @db.Decimal(10,2)

  finalAmount Decimal @db.Decimal(10,2)

  selectedMonths Json?

  invoice FeeInvoice  @relation(fields:[invoiceId],references:[id])

  feeHead FeeHead  @relation(fields:[feeHeadId],references:[id])

  createdAt DateTime @default(now())

  @@index([invoiceId])

}
enum BatchStatus {
  PENDING
  PARTIALLY_PAID
  PAID
  CANCELLED
}

model FeeInvoiceBatch {
  id            String   @id @default(uuid())

  schoolId      String
  sessionId     String
  classId       String
  sectionId     String

  invoiceName   String
  dateFrom      DateTime
  dateTo        DateTime
  dueDate       DateTime
  status        BatchStatus @default(PENDING)

  totalStudents Int      @default(0)
  totalAmount   Decimal  @default(0)
  paidAmount    Decimal  @default(0)
  pendingAmount Decimal  @default(0)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  school        School          @relation(fields: [schoolId], references: [id])
  session       AcademicSession @relation(fields: [sessionId], references: [id])
  class         Class           @relation(fields: [classId], references: [id])
  section       Section         @relation(fields: [sectionId], references: [id])

  invoices      FeeInvoice[]

  @@unique([schoolId, sessionId, classId, sectionId, invoiceName, dateFrom, dateTo])
  @@index([schoolId])
  @@index([sessionId])
  @@index([classId])
  @@index([sectionId])
}
enum PaymentStatus {
  SUCCESS
  REFUNDED
}

model FeePayment {
  id            String        @id @default(uuid())

  invoiceId     String

  amount        Decimal       @db.Decimal(10, 2)
  paymentMode   PaymentMode
  status        PaymentStatus @default(SUCCESS)

  paymentDate   DateTime      @default(now())

  transactionId String?
  remarks       String?

  invoice       FeeInvoice @relation(fields: [invoiceId], references: [id])

  receipt       FeeReceipt?

  createdAt     DateTime @default(now())

  @@index([invoiceId])
}


model FeeReceipt {
  id          String   @id @default(uuid())

  invoiceId   String
  paymentId   String   @unique

  receiptNo   String   @unique

  generatedAt DateTime @default(now())
  createdAt   DateTime @default(now())

  invoice     FeeInvoice @relation(fields: [invoiceId], references: [id])

  payment     FeePayment @relation(fields: [paymentId],references: [id])

  @@index([invoiceId])
}


model FeeFine {

  id String @id @default(uuid())

  schoolId String

  studentId String

  amount Decimal @db.Decimal(10,2)

  reason String

  appliedDate DateTime @default(now())

  school School  @relation(fields:[schoolId],references:[id])

  student Student  @relation(fields:[studentId],references:[id])

  createdAt DateTime @default(now())

  @@index([studentId])

}

enum IdCardOrientation {
  PORTRAIT
  LANDSCAPE
}

enum IdCardSide {
  FRONT_ONLY
  FRONT_BACK
}

enum IdCardStatus {
  ACTIVE
  EXPIRED
  BLOCKED
}

enum IdCardDesign {
  PURPLE_CURVE
  ORANGE_WAVE
  BLUE_MODERN
  GREEN_CLASSIC
  RED_MINIMAL
  DARK_PREMIUM
}

enum IdCardField {
  STUDENT_NAME
  EMAIL
  ADMISSION_NO
  ROLL_NO
  CLASS
  SECTION
  DOB
  BLOOD_GROUP
  GENDER
  FATHER_NAME
  MOTHER_NAME
  MOBILE
  ADDRESS
  SESSION
  QR_CODE
  BARCODE
  PRINCIPAL_SIGNATURE
}

model StudentIdCardTemplate {
  id String @id @default(uuid())

  schoolId  String
  sessionId String?

  templateName String

  design      IdCardDesign      @default(GREEN_CLASSIC)
  orientation IdCardOrientation @default(PORTRAIT)
  cardSide    IdCardSide        @default(FRONT_ONLY)

  width  Decimal @default(54)
  height Decimal @default(86)

  primaryColor   String?
  secondaryColor String?
  textColor      String?

  backgroundImage String?
  frontBackground String?
  backBackground  String?

  defaultFields IdCardField[] @default([])

  frontConfig Json?
  backConfig  Json?

  isSystem  Boolean @default(false)
  isDefault Boolean @default(false)
  isActive  Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school  School           @relation(fields: [schoolId], references: [id])
  session AcademicSession? @relation(fields: [sessionId], references: [id])

  idCards StudentIdCard[]

  @@unique([schoolId, templateName])
  @@index([schoolId, sessionId])
  @@index([schoolId, isActive])
}


model StudentIdCard {
  id              String       @id @default(uuid())

  schoolId        String
  sessionId       String
  studentId       String
  templateId      String

  cardNumber      String
  qrCodeValue     String?
  barcodeValue    String?

  issueDate       DateTime     @default(now())
  expiryDate      DateTime?

  status          IdCardStatus @default(ACTIVE)

  generatedAt     DateTime     @default(now())
  generatedById   String?

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  school          School                @relation(fields: [schoolId], references: [id])
  session         AcademicSession       @relation(fields: [sessionId], references: [id])
  student         Student               @relation(fields: [studentId], references: [id])
  template        StudentIdCardTemplate @relation(fields: [templateId], references: [id])
  generatedBy     User?                 @relation(fields: [generatedById], references: [id])

  @@unique([schoolId, sessionId, studentId])
  @@unique([schoolId, cardNumber])

  @@index([schoolId, sessionId])
  @@index([studentId])
  @@index([templateId])
}

model AuditLog {
  id          String   @id @default(uuid())
  schoolId    String?
  userId      String
  module      String
  action      String
  description String?
  ipAddress   String?
  createdAt   DateTime @default(now())
  school      School?  @relation(fields: [schoolId], references: [id])
  user        User     @relation(fields: [userId], references: [id])

  @@index([schoolId])
  @@index([userId])
}


