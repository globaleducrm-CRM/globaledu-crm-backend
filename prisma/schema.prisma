generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SchoolStatus {
  APPROVED
  PENDING
  INACTIVE
  SUSPENDED
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum StudentStatus {
  ACTIVE
  INACTIVE
  TRANSFERRED
  DROPPED
}

model Role {
  id              String           @id @default(uuid())
  name            String           @unique
  description     String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  rolePermissions RolePermission[]
  users           User[]
}

model Permission {
  id              String           @id @default(uuid())
  name            String           @unique
  description     String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  rolePermissions RolePermission[]
}

model RolePermission {
  id           String     @id @default(uuid())
  roleId       String
  permissionId String
  createdAt    DateTime   @default(now())
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

model User {
  id                  String   @id @default(uuid())
  schoolId            String?
  roleId              String?

  name                String
  email               String   @unique
  mobile              String?  @unique
  password            String

  isActive            Boolean  @default(true)

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  resetPasswordExpire DateTime?
  resetPasswordToken  String?



  role                Role?    @relation(fields: [roleId], references: [id])
  school              School?  @relation(fields: [schoolId], references: [id])

  // No teacherId
  teacher             Teacher?
  student Student?
  parent Parent?



  auditLogs           AuditLog[]
}

model School {
  id              String            @id @default(uuid())
  name            String            @unique(map: "School_schoolName_key")
  schoolCode      String            @unique
  board           String
  affiliationNo   String?
  email           String
  phone           String
  website         String?
  logo            String?
  addressLine     String
  city            String
  district        String
  state           String
  pincode         String?
  country         String
  principalName   String?
  status          SchoolStatus      @default(PENDING)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  adminEmail      String?
  adminName       String?
  adminPhone      String?
  banner          String?
  ownerEmail      String?
  ownerName       String?
  ownerPhone      String?
  principalEmail  String?
  principalPhone  String?
  schoolBoardCode String
  sessions        AcademicSession[]
  auditLogs       AuditLog[]
  classes         Class[]
  parents         Parent[]
  sections        Section[]
  students        Student[]
  subjects        Subject[]
  teachers        Teacher[]
  users           User[]
  teacherSubjects TeacherSubject[]

  @@index([schoolCode])
}

model AcademicSession {
  id          String    @id @default(uuid())
  schoolId    String
  sessionName String
  startDate   DateTime
  endDate     DateTime
  isCurrent   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  school      School    @relation(fields: [schoolId], references: [id])
  classes     Class[]
  students    Student[]
  sections    Section[]
  subjects    Subject[]
  teachers    Teacher[]



  @@index([schoolId])
}

model Class {
  id         String          @id @default(uuid())
  schoolId   String
  
  className  String
  sortName   String
  classOrder Int?
  status     Boolean         @default(true)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  school     School          @relation(fields: [schoolId], references: [id])
  sessionId  String
  session    AcademicSession @relation(fields: [sessionId], references: [id])
  sections   Section[]
  students   Student[]
  teacherSubjects TeacherSubject[]

  @@unique([schoolId, sessionId, className])
  @@index([schoolId])
  @@index([sessionId])
}



model Section {
  id          String    @id @default(uuid())
  schoolId    String
  classId     String
  sectionName String
  capacity    Int?
  
  classTeacherId     String?
  coClassTeacherId   String?
  status      Boolean    @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  class       Class     @relation(fields: [classId], references: [id])
  school      School    @relation(fields: [schoolId], references: [id])
   
  classTeacher       Teacher?        @relation("ClassTeacher", fields: [classTeacherId], references: [id])
  coClassTeacher     Teacher?        @relation("CoClassTeacher", fields: [coClassTeacherId], references: [id])
  sessionId  String?
  session    AcademicSession? @relation(fields: [sessionId], references: [id])
  students    Student[]
   teacherSubjects   TeacherSubject[]

  @@unique([classId, sectionName])
  @@index([schoolId])
  @@index([classId])
}

model Subject {
  id          String   @id @default(uuid())
  schoolId    String

  subjectName String
  shortName   String?      // ENG, MAT, SCI
  subjectCode String

  description String?      // Optional
  
  

  status      Boolean  @default(true)

  teacherSubjects TeacherSubject[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  school      School   @relation(fields: [schoolId], references: [id])

  sessionId  String?
  session    AcademicSession? @relation(fields: [sessionId], references: [id])

  @@unique([schoolId, subjectCode])
  @@unique([schoolId, subjectName])

  @@index([schoolId])
}

model Teacher {
  id            String    @id @default(uuid())
  schoolId      String
  image         String?
  employeeId    String
  firstName     String
  lastName      String?
  gender        Gender?

  email         String?
  mobile        String?
  dob           DateTime?
  qualification String?
  experience    Int?
  salary        Decimal? @db.Decimal(10,2)

  status        Boolean @default(true)

  joiningDate   DateTime?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  school        School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  userId        String? @unique
  user          User?   @relation(fields: [userId], references: [id])
  sessionId  String?
  session    AcademicSession? @relation(fields: [sessionId], references: [id])

  subjects      TeacherSubject[]

  classTeacherSections   Section[] @relation("ClassTeacher")
  coClassTeacherSections Section[] @relation("CoClassTeacher")

  @@unique([schoolId, employeeId])
  @@index([schoolId])
}

model TeacherSubject {
  id          String @id @default(uuid())
  schoolId    String
  teacherId   String
  classId     String
  sectionId   String
  subjectId   String

  school      School  @relation(fields: [schoolId], references: [id])
  teacher     Teacher @relation(fields: [teacherId], references: [id])
  class       Class   @relation(fields: [classId], references: [id])
  section     Section @relation(fields: [sectionId], references: [id])
  subject     Subject @relation(fields: [subjectId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([schoolId])
  @@index([teacherId])
  @@unique([teacherId, classId, sectionId, subjectId])
}


model Parent {
  id             String   @id @default(uuid())
  schoolId       String

  fatherName     String
  fatherMobile   String
  fatherEmail    String

  motherName     String?
  motherMobile   String?
  motherEmail    String?

  

  address        String?
  city           String?
  state          String?
  pincode        String?

  fatherOccupation String?
  motherOccupation String?

  fatherAadhaar    String?
  motherAadhaar    String?

  annualIncome     Float?

  officeAddress    String?
  status        Boolean @default(true)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  school         School @relation(fields: [schoolId], references: [id])
  userId          String? @unique
  user            User? @relation(fields: [userId], references: [id])
  students       Student[]

  @@index([schoolId])
  @@unique([schoolId, fatherEmail])
}



model Student {
  id              String          @id @default(uuid())

  schoolId        String
  sessionId       String
  parentId        String?

  classId         String?
  sectionId       String?

  admissionNo     String
  rollNo          Int?

  image           String?

  firstName       String
  middleName      String?
  lastName        String?

  email           String
  mobile          String

  gender          Gender?
  dob             DateTime?

  bloodGroup      String?
  nationality     String? @default("India")

  religion        String?
  caste           String?
  category        String?

  previousSchool  String?

  admissionDate   DateTime @default(now())

  transport       Boolean @default(false)
  hostel          Boolean @default(false)

  medicalHistory  String?

 

  // NEW FIELDS

  address         String?
  city            String?
  state           String?
  pincode         String?
  country         String? @default("India")

  height          Float?
  weight          Float?

  status          StudentStatus @default(ACTIVE)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  school          School           @relation(fields: [schoolId], references: [id])
  session         AcademicSession  @relation(fields: [sessionId], references: [id])

  class           Class?           @relation(fields: [classId], references: [id])
  section         Section?         @relation(fields: [sectionId], references: [id])

  parent          Parent?          @relation(fields: [parentId], references: [id])

  userId          String? @unique
  user            User? @relation(fields: [userId], references: [id])

  transportInfo StudentTransport?

  @@unique([schoolId, admissionNo])
  @@unique([schoolId, email])

  @@index([schoolId])
  @@index([sessionId])
  @@index([classId])
  @@index([sectionId])
  @@index([parentId])
}



model StudentTransport{
    id String @id @default(uuid())

    studentId String @unique

    required Boolean @default(false)

    pickupPoint String?
    pickupTime String?
    dropTime String?

    conductorName String?
    conductorPhone String?

    student Student @relation(fields:[studentId],references:[id])

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model AuditLog {
  id          String   @id @default(uuid())
  schoolId    String?
  userId      String
  module      String
  action      String
  description String?
  ipAddress   String?
  createdAt   DateTime @default(now())
  school      School?  @relation(fields: [schoolId], references: [id])
  user        User     @relation(fields: [userId], references: [id])

  @@index([schoolId])
  @@index([userId])
}


